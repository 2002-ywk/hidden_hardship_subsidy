# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MySQL database used by Prisma.
DATABASE_URL="mysql://root:your_password@172.30.80.1:3306/yxbztest"

# Session secret for server-side login state.
SESSION_SECRET="change-me-in-production"

# JMU unified auth (compatible with union-management-next naming).
# If left empty, server.ts falls back to built-in JMU CAS defaults.
JMU_AUTH_CLIENT_ID="OAuth2"
JMU_AUTH_CLIENT_SECRET="3A6Rh2bpFkfNAtJW0D6ebo"
JMU_AUTH_REDIRECT_URI="http://210.34.132.91:3000/api/auth/callback/jmu"
JMU_AUTH_AUTHORIZE_URL="https://cas.paas.jmu.edu.cn/cas/oauth2.0/authorize"
JMU_AUTH_TOKEN_URL="https://cas.paas.jmu.edu.cn/cas/oauth2.0/accessToken"
JMU_AUTH_USERINFO_URL="https://cas.paas.jmu.edu.cn/cas/oauth2.0/profile"
JMU_AUTH_SCOPE="openid"
JMU_AUTH_SIGNOUT_REDIRECT_URL="http://210.34.132.91:3000/login"

# Optional: tune sync performance.
# SYNC_WRITE_CONCURRENCY controls parallel DB writes for counselor/difficulty sync (default 4).
SYNC_WRITE_CONCURRENCY="4"
# CAFETERIA_INSERT_BATCH_SIZE controls batch size for cafeteria transaction bulk upserts (default 1500).
CAFETERIA_INSERT_BATCH_SIZE="1500"

# Full refresh policy:
# - Default 0: if API returns 0 rows, abort to avoid accidental hard delete.
# - Set to 1 to allow wiping tables even when API returns empty.
FULL_REFRESH_ALLOW_EMPTY="0"

# Optional: generic sync endpoint that directly returns SyncRunRequest structure.
DATA_PLATFORM_SYNC_URL=""
DATA_PLATFORM_SYNC_TOKEN=""

# Message platform (independent from data platform; recommended to configure explicitly).
# If MESSAGE_PLATFORM_* is empty, server will fallback to DATA_PLATFORM_* for token credentials.
MESSAGE_PLATFORM_TOKEN_URL="https://poa.paas.jmu.edu.cn/oauth2/token"
MESSAGE_PLATFORM_CLIENT_ID=""
MESSAGE_PLATFORM_CLIENT_SECRET=""
MESSAGE_PLATFORM_SCOPE="messagecenter:v1:sendMessage"
MESSAGE_PLATFORM_API_URL="https://poa.paas.jmu.edu.cn/apis/messagecenter/v1/poaMessage/messageSend"
MESSAGE_PLATFORM_APP_ID="gtxkno3gadcbsracqkxihlv5jda"
MESSAGE_PLATFORM_DEFAULT_MESSAGE_TYPE_CODE="MT1686736235000"
# 0: disable auto send after review; 1: enable.
MESSAGE_PLATFORM_AUTO_SEND_REVIEW="0"
# 0: disable auto reminder to next-stage reviewer after approve; 1: enable.
MESSAGE_PLATFORM_AUTO_SEND_NEXT_STAGE_REMINDER="1"
# Optional: force auto-send to a test receiver instead of studentId during联调.
MESSAGE_PLATFORM_REVIEW_TEST_RECEIVER=""
# Optional: force candidate reminder to a fixed receiver during联调.
MESSAGE_PLATFORM_CANDIDATE_REMINDER_TEST_RECEIVER=""
# 1: enable auto reminder scheduler for candidate reviews; 0: disable.
MESSAGE_PLATFORM_AUTO_CANDIDATE_REMINDER="1"
# Scheduler interval in milliseconds (minimum 60000). Default 600000 (10 minutes).
MESSAGE_PLATFORM_AUTO_CANDIDATE_REMINDER_INTERVAL_MS="600000"

# JMU data platform OAuth2 + student basic API settings.
DATA_PLATFORM_TOKEN_URL="https://poa.paas.jmu.edu.cn/oauth2/token"
DATA_PLATFORM_CLIENT_ID="7itulbjzgzvdeucxspxyabixlw"
DATA_PLATFORM_CLIENT_SECRET="1HvAHLWmX-YI2LLirTMj1cekqy8F_v235omGMLnLW0o="
DATA_PLATFORM_STUDENT_SCOPE="dataAssetsApiGongGongXueShengXinXi:v4:GGFW_XSJBXX"
DATA_PLATFORM_STUDENT_API_URL="https://poa.paas.jmu.edu.cn/apis/dataAssetsApiGongGongXueShengXinXi/v4/2d6a9c906ecf11ec055dbb406a512cf0/getData"
DATA_PLATFORM_STUDENT_XSDQZTM="01"
DATA_PLATFORM_STUDENT_SCBJ="0"
DATA_PLATFORM_ORG_UNIT_SCOPE="dataAssetsApiGongGongZuZhiJiGouXinXi:v1:GG_ZZJGXXA"
DATA_PLATFORM_ORG_UNIT_API_URL="https://poa.paas.jmu.edu.cn/apis/dataAssetsApiGongGongZuZhiJiGouXinXi/v1/9ac555606e9c11ec055dbb406a512cf0/getData"
DATA_PLATFORM_ORG_POST_SCOPE="dataAssetsApiGongGongZuZhiJiGouXinXi:v1:GGWF-YXSGWXX"
